<section id="contact" class="section-shell bg-bg-alt pb-32">
  <div class="absolute top-1/2 -right-37.5 w-125 h-125 rounded-full border border-orange-500/5 -translate-y-1/2 pointer-events-none"></div>

  <div class="mx-auto max-w-5xl">
    <p class="reveal mb-2 font-body text-sm font-semibold tracking-[0.08em] text-accent uppercase">Get In Touch</p>
    <h2 class="reveal mb-12 text-[clamp(32px,5vw,48px)] leading-[1.1] font-display font-bold tracking-[-0.02em] text-text" style="transition-delay:80ms">
      Let's Work <span class="text-accent">Together</span>
    </h2>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
      <div class="reveal flex flex-col gap-6" style="transition-delay:160ms">
        <p class="mb-2 text-base leading-relaxed font-body text-muted">
          Don't be afraid to contact me if you have any questions. Leave your email and I will get back to you within 24 hours.
        </p>

        <div class="contact-info-card">
          <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-[10px] bg-[rgba(252,158,3,0.12)] text-accent">
            <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M4 6h16v12H4z"/><path d="m4 7 8 6 8-6"/></svg>
          </div>
          <div>
            <div class="font-body text-[11px] font-semibold uppercase tracking-[0.04em] text-muted">Email</div>
            <div class="font-body text-sm font-medium mt-0.5 text-text">mohammedkudmani@gmail.com</div>
          </div>
        </div>

        <div class="contact-info-card">
          <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-[10px] bg-[rgba(252,158,3,0.12)] text-accent">
            <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M22 16.9v3a2 2 0 0 1-2.2 2A19.7 19.7 0 0 1 11.2 19a19.3 19.3 0 0 1-6-6A19.7 19.7 0 0 1 2.1 4.2 2 2 0 0 1 4 2h3a2 2 0 0 1 2 1.7c.1.8.3 1.6.6 2.3a2 2 0 0 1-.4 2.1l-1.2 1.2a16 16 0 0 0 6 6l1.2-1.2a2 2 0 0 1 2.1-.4c.8.3 1.5.5 2.3.6A2 2 0 0 1 22 16.9z"/></svg>
          </div>
          <div>
            <div class="font-body text-[11px] font-semibold uppercase tracking-[0.04em] text-muted">Phone</div>
            <div class="font-body text-sm font-medium mt-0.5 text-text">+962 7 9643 2562</div>
          </div>
        </div>

        <div class="contact-info-card">
          <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-[10px] bg-[rgba(252,158,3,0.12)] text-accent">
            <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M12 22s7-5.9 7-12a7 7 0 1 0-14 0c0 6.1 7 12 7 12z"/><circle cx="12" cy="10" r="2.5"/></svg>
          </div>
          <div>
            <div class="font-body text-[11px] font-semibold uppercase tracking-[0.04em] text-muted">Location</div>
            <div class="font-body text-sm font-medium mt-0.5 text-text">Amman, Jordan</div>
          </div>
        </div>
      </div>

      <div class="reveal surface-card rounded-[20px] p-7 shadow-[0_0_7px_4px_rgba(0,0,0,0.15)] backdrop-blur-md" style="transition-delay:260ms">
        <form id="contact-form">
          <div class="mb-4">
            <label class="block font-body text-xs font-semibold uppercase tracking-[0.04em] mb-1.5 text-muted">Email</label>
            <input type="email" name="email" placeholder="you@domain.com" class="form-input" required />
          </div>
          <div class="mb-4">
            <label class="block font-body text-xs font-semibold uppercase tracking-[0.04em] mb-1.5 text-muted">Name</label>
            <input type="text" name="name" placeholder="Your name" class="form-input" required />
          </div>
          <div class="mb-5">
            <label class="block font-body text-xs font-semibold uppercase tracking-[0.04em] mb-1.5 text-muted">Message</label>
            <textarea name="msg" rows={4} placeholder="Tell me about your project..." class="form-input resize-none" required></textarea>
          </div>
          <button type="submit" class="w-full px-6 py-3.5 rounded-[10px] font-body text-[15px] font-semibold text-white bg-accent border-none cursor-pointer transition-all duration-250 hover:bg-accent-hover hover:scale-[1.02]">
            Send Message →
          </button>
        </form>

        <div id="success-state" class="text-center py-10 hidden">
          <div class="mx-auto mb-4 flex h-14 w-14 items-center justify-center rounded-full bg-[rgba(18,184,134,.15)] text-success">
            <svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="2"><path d="m20 6-11 11-5-5"/></svg>
          </div>
          <h3 class="font-display text-xl font-semibold mb-2 text-text">Message Sent!</h3>
          <p class="font-body text-sm text-muted">I'll get back to you within 24 hours.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const successState = document.getElementById('success-state') as HTMLElement | null;

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    form.classList.add('hidden');
    successState?.classList.remove('hidden');
  });
</script>
