---
interface Props {
  size?: number
  color?: string
}

const { size = 24, color = '#F05032' } = Astro.props
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  width={size}
  height={size}
  viewBox="0 0 64 64"
  fill="none"
  aria-hidden="true"
>
  <rect
    x="32"
    y="6"
    width="40"
    height="40"
    rx="8"
    transform="rotate(45 32 6)"
    fill={color}></rect>
  <circle cx="24" cy="24" r="3.3" fill="#FFFFFF"></circle>
  <circle cx="32" cy="32" r="3.3" fill="#FFFFFF"></circle>
  <circle cx="40" cy="40" r="3.3" fill="#FFFFFF"></circle>
  <path
    d="M26.5 26.5 29.5 29.5M34.5 34.5 37.5 37.5M32 28.5v7"
    stroke="#FFFFFF"
    stroke-width="2.6"
    stroke-linecap="round"></path>
</svg>
