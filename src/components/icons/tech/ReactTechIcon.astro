---
interface Props {
  size?: number;
  color?: string;
}

const { size = 26, color = '#61DAFB' } = Astro.props;
---
<svg xmlns="http://www.w3.org/2000/svg" width={size} height={size} viewBox="0 0 64 64" fill="none" aria-hidden="true">
  <circle cx="32" cy="32" r="4.2" fill={color} />
  <ellipse cx="32" cy="32" rx="23" ry="9.2" stroke={color} stroke-width="3" />
  <ellipse cx="32" cy="32" rx="23" ry="9.2" stroke={color} stroke-width="3" transform="rotate(60 32 32)" />
  <ellipse cx="32" cy="32" rx="23" ry="9.2" stroke={color} stroke-width="3" transform="rotate(-60 32 32)" />
</svg>
